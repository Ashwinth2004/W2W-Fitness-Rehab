# ── Dependencies & build output ─────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vercel/
*.local

# ── Environment & secrets (NEVER commit) ─────────────────────────────────────
.env
.env.*
!.env.example
# Firebase Admin service-account private keys (downloaded JSON) & other secrets
*serviceAccount*.json
*service-account*.json
*-firebase-adminsdk-*.json
.runtimeconfig.json
*.pem
*.key
*.p8
*.p12

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── Firebase tooling (keep firebase.json / .firebaserc / *.rules / indexes) ──
.firebase/
firebase-debug.log*
firestore-debug.log*
database-debug.log*
ui-debug.log*
pubsub-debug.log*

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editors / IDEs ───────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json

# ── Tooling caches ───────────────────────────────────────────────────────────
coverage/
.cache/
.eslintcache

# ── Agent / test scratch artifacts ───────────────────────────────────────────
.claude/
.playwright-mcp/
# Stray screenshots / generated PDFs left in the repo root (real assets live in
# public/ and src/, so root-level ones are always scratch output).
/*.png
/*.jpg
/*.jpeg
/*.webp
*.pdf

# ── Source media folders not shipped in the build ────────────────────────────
GALLERY PHOTOS/
WEBSITE ADDON PHOTOS/
ppt-assets/
*.pptx

# ============================================================================
#  W2W Fitness & Rehab — Environment variables
#  Copy this file to ".env" for local dev, and add the same keys in
#  Vercel → Project → Settings → Environment Variables for production.
# ============================================================================

# --- Firebase Web SDK (client) -------------------------------------------
# Firebase console → Project settings → "Your apps" → SDK setup & config.
# These are PUBLIC by design (safe to ship in the browser); access is
# controlled by Firestore security rules + Firebase Auth.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# The single admin's login email (used to gate the /admin area).
VITE_ADMIN_EMAIL=admin@w2wfitnessandrehab.in

# --- Resend (server, enquiry + reminder emails) --------------------------
# Create a free account at https://resend.com → API Keys.
RESEND_API_KEY=
# "From" must be a verified Resend address. Until you verify your own domain,
# you can use the shared sandbox sender below (works to your own inbox).
ENQUIRY_FROM_EMAIL=W2W Fitness & Rehab <noreply@w2wfitnessandrehab.in>
# Where new enquiries/bookings are delivered (comma-separated for multiple).
ENQUIRY_TO_EMAIL=contact@w2wfitnessandrehab.in

# --- Firebase Admin (server, used by the reminder cron only) -------------
# Firebase console → Project settings → Service accounts → Generate new
# private key. Paste the WHOLE JSON on one line (keep the \n in private_key).
FIREBASE_SERVICE_ACCOUNT=

# Secret that protects the cron endpoint. Vercel Cron sends this automatically
# if you set it; you can also call the endpoint manually with ?key=...
CRON_SECRET=

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The single clinic admin = any signed-in Firebase user (only the admin
    // has an account). Tighten further by checking a specific email if needed:
    //   request.auth.token.email == 'admin@w2wfitnessandrehab.in'
    function isAdmin() {
      return request.auth != null;
    }

    // Public can submit enquiries; only the admin can read/manage them.
    match /enquiries/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Public booking writes here (auto-confirm). Documents contain client PII,
    // so reads are admin-only; public can only create.
    match /appointments/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Only booked time strings (no PII) — public read to show availability,
    // public write to reserve a slot during booking.
    match /availability/{date} {
      allow read: if true;
      allow write: if true;
    }

    // Running counter for unique client IDs — admin only.
    match /counters/{id} {
      allow read, write: if isAdmin();
    }

    // Client/patient CRM and all sub-data — admin only.
    match /clients/{id} {
      allow read, write: if isAdmin();
      match /{sub=**} {
        allow read, write: if isAdmin();
      }
    }

    // Testimonials & blog: public can read, admin manages.
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /posts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Video testimonials (Instagram reels): public read, admin manages.
    match /reels/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Workshops: public can read (to show open registrations), admin manages.
    match /workshops/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public seat counter for workshops (no PII) — read + write open, like
    // availability, so a public registration can reserve a seat atomically.
    match /workshopStats/{id} {
      allow read: if true;
      allow write: if true;
    }

    // Workshop registrations contain PII — public can only create; admin reads.
    match /workshopRegistrations/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}

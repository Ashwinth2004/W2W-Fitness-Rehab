rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Admin identity ----------------------------------------------------
    // Two admin Firebase Auth accounts (by uid):
    //   admin@w2w.in  (FULL_ADMIN_UID)  — full access to everything.
    //   admin2@w2w.in (uid below)       — LIMITED: the first five modules only
    //                                     (Enquiries, Appointments, Clients,
    //                                     Treatment + Dashboard). It must NOT
    //                                     reach Accounting, Blogs or Workshop
    //                                     data — enforced here, not just in the
    //                                     UI.
    // A custom claim {admin: true} grants full access (for Admin-SDK additions).
    // (Do NOT loosen isAdmin() to "request.auth != null" — that would let ANY
    // signed-up user read patient PII.)
    function isFullAdmin() {
      return request.auth != null && (
        request.auth.uid == 'dPoj1JEQ57TSFYaniLPsB0rAjFu2'
        || request.auth.token.admin == true
      );
    }
    // Any admin (full or limited) — for the shared, first-five-module data.
    function isAdmin() {
      return isFullAdmin() || (request.auth != null
        && request.auth.uid == 'jB0005vbkwOQiqNQBrm2Ikk6u3B3');
    }

    // ---- Validation helpers (for public, unauthenticated writes) -----------
    function data() { return request.resource.data; }
    function optStr(f, max) {
      return !(f in data()) || (data()[f] is string && data()[f].size() <= max);
    }
    function reqStr(f, max) {
      return data()[f] is string && data()[f].size() > 0 && data()[f].size() <= max;
    }

    // Public can submit enquiries; only the admin can read/manage them.
    match /enquiries/{id} {
      allow create: if isAdmin() || (
        data().size() <= 8 && data().status == 'new'
        && reqStr('name', 120)
        && optStr('phone', 20) && optStr('email', 200)
        && optStr('service', 100) && optStr('message', 3000)
      );
      allow read, update, delete: if isAdmin();
    }

    // Public booking create (auto-confirm). Documents contain PII, so reads are
    // admin-only; public create is shape-validated to curb spam/abuse.
    match /appointments/{id} {
      allow create: if isAdmin() || (
        data().size() <= 11 && data().status == 'confirmed'
        && data().date is string && data().date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data().time is string && data().time.matches('^[0-9]{2}:[0-9]{2}$')
        && reqStr('name', 120)
        && optStr('phone', 20) && optStr('email', 200)
        && optStr('service', 100) && optStr('notes', 2000) && optStr('source', 20)
      );
      allow read, update, delete: if isAdmin();
    }

    // Booked time strings only (no PII). Public read; public write constrained
    // to a single `times` list of bounded length (no arbitrary payloads).
    match /availability/{date} {
      allow read: if true;
      allow write: if isAdmin() || (
        data().keys().hasOnly(['times'])
        && data().times is list
        && data().times.size() <= 60
      );
    }

    // Running counter for unique client IDs — admin only.
    match /counters/{id} {
      allow read, write: if isAdmin();
    }

    // Client/patient CRM and all sub-data — admin only.
    match /clients/{id} {
      allow read, write: if isAdmin();
      match /{sub=**} {
        allow read, write: if isAdmin();
      }
    }

    // Testimonials, blog & reels: public read; managed in the Blogs/content
    // module → full admin only.
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isFullAdmin();
    }
    match /posts/{id} {
      allow read: if true;
      allow write: if isFullAdmin();
    }
    match /reels/{id} {
      allow read: if true;
      allow write: if isFullAdmin();
    }

    // Workshops: public read (to show open registrations); Workshop module is
    // full admin only.
    match /workshops/{id} {
      allow read: if true;
      allow write: if isFullAdmin();
    }

    // Public seat counter (no PII) — confirmed seats. Public reads it to show
    // remaining seats; only the full admin writes it (on approve/reject).
    match /workshopStats/{id} {
      allow read: if true;
      allow write: if isFullAdmin();
    }

    // Workshop registrations contain PII — public create (validated); only the
    // full admin (Workshop module) reads/manages them. Public create only; a
    // repeat write to the same (deterministic) doc id is an update → denied,
    // which enforces one registration per phone per workshop.
    match /workshopRegistrations/{id} {
      allow create: if isFullAdmin() || (
        data().size() <= 14 && data().status == 'pending'
        && reqStr('fullName', 120)
        && optStr('phone', 20) && optStr('email', 200)
        && optStr('qualification', 60) && optStr('reason', 3000)
        && optStr('attendedBefore', 10) && optStr('paidVia', 60)
        && optStr('workshopId', 80) && optStr('workshopTitle', 200)
      );
      allow read, update, delete: if isFullAdmin();
    }

    // Email-uniqueness guard for workshop registrations. Doc id is
    // `{workshopId}__{email}`; the body is empty. Public can only CREATE (never
    // update), so a second registration with the same email for the same
    // workshop is denied — giving email uniqueness without exposing any PII for
    // reads. Managed/cleared by the full admin only.
    match /workshopRegEmails/{id} {
      allow create: if isFullAdmin() || data().size() == 0;
      allow read, update, delete: if isFullAdmin();
    }

    // Therapists — shared (Treatment module needs them) → any admin.
    match /therapists/{id} { allow read, write: if isAdmin(); }
    // Accounting (patient charges) and expenses — Accounting module → full admin only.
    match /accounting/{id} { allow read, write: if isFullAdmin(); }
    match /expenses/{id} { allow read, write: if isFullAdmin(); }
    match /expenseCategories/{id} { allow read, write: if isFullAdmin(); }
  }
}
